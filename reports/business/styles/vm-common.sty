\newcommand{\placeholder}[1]{
  \begin{tcolorbox}[
    colback=VMWhite,
    colframe=VMBeige,
    boxrule=0.4pt,
    arc=1.5mm,
    left=3mm,
    right=3mm,
    top=2mm,
    bottom=2mm
  ]
  \textbf{\color{VMTan}To add:} #1
  \end{tcolorbox}
}

\newcommand{\metriccard}[2]{
  \begin{tcolorbox}[
    colback=VMWhite,
    colframe=VMBeige,
    boxrule=0.5pt,
    arc=1.5mm,
    left=3mm,
    right=3mm,
    top=2mm,
    bottom=2mm
  ]
  {\small\color{VMMutedText}#1}\\
  {\Large\bfseries\color{VMDeepTeal}#2}
  \end{tcolorbox}
}

% ---------------------------------------------------------
% Safe figure helper
% ---------------------------------------------------------
\newcommand{\maybegraphics}[2][0.95\linewidth]{
  \IfFileExists{#2}{
    \includegraphics[width=#1]{#2}
  }{
    \begin{tcolorbox}[
      colback=VMSoftCream,
      colframe=VMBeige,
      boxrule=0.6pt,
      width=#1,
      arc=1.5mm
    ]
    Missing figure: \texttt{#2}
    \end{tcolorbox}
  }
}

\newcommand{\reportfigure}[4][0.95\linewidth]{
\begin{figure}[htbp]
  \centering
  \maybegraphics[#1]{../figures/#2.pdf}
  \caption{#3}
  \label{#4}
\end{figure}
}

\endinput
